# ============================================================
# 🔧 FILE DI CONFIGURAZIONE PRODUZIONE - .env.production
# ============================================================
# Questo è il template per la configurazione di produzione Docker.
#
# ISTRUZIONI PER IL DEPLOYMENT:
# 1. Copia questo file come ".env" nella directory root del progetto
#    cp .env.production.template .env
# 2. Sostituisci TUTTI i valori "changeme_*" con password sicure
# 3. NON committare mai il file .env su Git!
# 4. Genera password sicure con:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# ⚠️ IMPORTANTE: Questo file contiene configurazioni per Docker Compose
# Le variabili sono lette da docker-compose.yml
# ============================================================

# === Applicazione ===
APP_NAME="Gestionale Collaboratori e Progetti"
ENVIRONMENT=production
DEBUG=False  # ⚠️ IMPORTANTE: DEVE essere False in produzione!

# === Porte Esterne (mapping host:container) ===
# Queste sono le porte ESTERNE su cui i servizi saranno accessibili
BACKEND_PORT=8000
FRONTEND_PORT=3001
DB_PORT=5433  # PostgreSQL esposto su 5433 per evitare conflitti con installazioni locali
REDIS_PORT=6379

# === Database PostgreSQL ===
# ⚠️ CAMBIA QUESTE CREDENZIALI IN PRODUZIONE!
# Genera password complesse (almeno 32 caratteri, alfanumerici + simboli)
DB_NAME=gestionale
DB_USER=admin
DB_PASSWORD=changeme_in_production_use_strong_password_here

# === Redis Cache ===
# ⚠️ IMPOSTA PASSWORD SICURA IN PRODUZIONE!
REDIS_PASSWORD=changeme_redis_pwd_use_strong_password_here

# === Sicurezza e Autenticazione ===
# ⚠️ CRITICO: Genera chiavi sicure per produzione!
# Comando per generare chiave sicura:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   oppure
#   openssl rand -hex 32
JWT_SECRET_KEY=changeme_secret_key_super_sicura_da_sostituire_in_produzione

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60  # 1 ora
REFRESH_TOKEN_EXPIRE_DAYS=7

# === CORS (Cross-Origin Resource Sharing) ===
# ⚠️ In produzione: specificare SOLO i domini autorizzati!
# Esempio per produzione:
#   BACKEND_CORS_ORIGINS=https://gestionale.tuo-dominio.com,https://app.tuo-dominio.com
#
# Per sviluppo locale con Docker:
BACKEND_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://frontend

# === Frontend Configuration ===
# URL dell'API backend come visto dal BROWSER dell'utente
# Se usi un reverse proxy (es. Nginx), usa l'URL pubblico
REACT_APP_API_URL=http://localhost:8000

# === Server Configuration (Backend) ===
WORKERS=2  # Numero worker Gunicorn (regola: CPU cores * 2 + 1)
TIMEOUT=60  # Timeout richieste HTTP (secondi)
GRACEFUL_TIMEOUT=20  # Tempo per chiusura graceful dei worker

# === Logging ===
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ============================================================
# CHECKLIST SICUREZZA PRIMA DEL DEPLOYMENT:
# ============================================================
# [ ] Cambiare DB_PASSWORD con password complessa (32+ caratteri)
# [ ] Cambiare REDIS_PASSWORD con password complessa (32+ caratteri)
# [ ] Generare JWT_SECRET_KEY sicura (32+ caratteri random)
# [ ] Impostare DEBUG=False
# [ ] Configurare CORS con domini specifici (non wildcard)
# [ ] Verificare REACT_APP_API_URL punta al backend corretto
# [ ] Configurare backup automatici del database
# [ ] Impostare HTTPS/TLS se esposto su internet
# [ ] Configurare firewall per limitare accesso DB (porta 5433)
# [ ] Abilitare monitoring e log aggregation
# [ ] Configurare rate limiting
# [ ] Eseguire security audit:
#     docker-compose exec backend pip-audit
#     docker-compose exec frontend npm audit
# ============================================================

# ============================================================
# COMANDI UTILI PER IL DEPLOYMENT:
# ============================================================
# Avvia stack:
#   docker-compose up -d
#
# Rebuild dopo modifiche:
#   docker-compose up -d --build
#
# View logs:
#   docker-compose logs -f
#   docker-compose logs -f backend
#   docker-compose logs -f frontend
#
# Stop stack:
#   docker-compose down
#
# Remove volumes (⚠️ ELIMINA DATI!):
#   docker-compose down -v
#
# Backup database:
#   docker-compose exec db pg_dump -U admin gestionale > backup.sql
#
# Restore database:
#   docker-compose exec -T db psql -U admin gestionale < backup.sql
# ============================================================
