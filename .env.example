# ============================================================
# 🔧 FILE DI CONFIGURAZIONE - .env.example
# ============================================================
# Questo è un file di esempio per le variabili d'ambiente.
#
# ISTRUZIONI:
# 1. Copia questo file come ".env" nella directory root
# 2. Modifica i valori con le tue configurazioni
# 3. NON committare mai il file .env su Git!
#
# Per creare il file .env:
#   cp .env.example .env
#
# ⚠️ SICUREZZA IMPORTANTE:
# - Il file .env contiene dati sensibili (password, chiavi, token)
# - È già incluso in .gitignore per prevenire commit accidentali
# - Genera password sicure per produzione
# - Ruota regolarmente le chiavi di sicurezza
# ============================================================

# === Applicazione ===
APP_NAME="Gestionale Collaboratori e Progetti"
APP_ENV=development  # development | production | staging
APP_VERSION=3.0.0
DEBUG=True  # False in produzione!

# === Server ===
HOST=0.0.0.0
PORT=8000
BACKEND_PORT=8000
FRONTEND_PORT=3001
WORKERS=2  # Numero worker Gunicorn (CPU cores * 2 + 1)
TIMEOUT=60
GRACEFUL_TIMEOUT=20

# === Database PostgreSQL ===
# ⚠️ CAMBIA QUESTE CREDENZIALI IN PRODUZIONE!
DB_NAME=gestionale
DB_USER=admin
DB_PASSWORD=changeme_in_production
DB_HOST=localhost  # In Docker: "db"
DB_PORT=5432  # Porta esterna: 5433 (in docker-compose)

# Connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_ECHO=False  # True per debug SQL

# URL completo (alternativa ai parametri separati)
DATABASE_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# === Redis Cache ===
# ⚠️ IMPOSTA PASSWORD IN PRODUZIONE!
REDIS_HOST=localhost  # In Docker: "redis"
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_pwd
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# === Sicurezza e Autenticazione ===
# ⚠️ CRITICO: Genera chiavi sicure per produzione!
#
# Genera una chiave sicura con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   oppure
#   openssl rand -hex 32
#
JWT_SECRET_KEY=changeme_secret_key_super_sicura_da_sostituire_in_produzione
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60  # 1 ora
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
PWD_HASH_ALGORITHM=bcrypt
PWD_SALT_ROUNDS=12

# === CORS (Cross-Origin Resource Sharing) ===
# Domini autorizzati (separati da virgola)
# ⚠️ In produzione: specificare solo domini autorizzati!
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

# === Logging ===
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=logs/gestionale.log
LOG_FORMAT=json  # json | text
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# === Email (opzionale per notifiche) ===
ENABLE_EMAIL=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=no-reply@gestionale.local
EMAIL_FROM_NAME="Gestionale Collaboratori"

# === Upload File ===
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# === Backup Automatico ===
ENABLE_AUTO_BACKUP=True
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_HOUR=2  # Ora del backup giornaliero (0-23)

# === Feature Flags (Abilita/Disabilita Funzionalità) ===
ENABLE_SWAGGER_DOCS=True  # False in produzione per sicurezza
ENABLE_MONITORING=True
ENABLE_AUDIT_LOG=True
ENABLE_PERFORMANCE_TRACKING=True

# Rate Limiting (protezione da abuso API)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# === Monitoring e Metriche ===
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# Sentry (Error Tracking - opzionale)
SENTRY_ENABLED=False
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# === Timezone e Localizzazione ===
TZ=Europe/Rome
LANGUAGE=it
LOCALE=it_IT.UTF-8

# === Environment ===
ENVIRONMENT=development  # development | production | staging

# === Secrets - Servizi Esterni ===
# Se usi servizi esterni, aggiungi qui le chiavi
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=

# ============================================================
# CHECKLIST SICUREZZA PRODUZIONE:
# ============================================================
# [ ] Cambiare tutte le password di default
# [ ] Generare JWT_SECRET_KEY sicura (32+ caratteri random)
# [ ] Impostare DEBUG=False
# [ ] Configurare CORS con domini specifici
# [ ] Abilitare HTTPS/TLS
# [ ] Configurare backup automatici
# [ ] Impostare log retention policy
# [ ] Abilitare monitoring
# [ ] Configurare firewall database
# [ ] Usare password PostgreSQL complesse
# [ ] Limitare accesso Redis con password
# [ ] Verificare permessi file e directory
# ============================================================

# ============================================================
# FINE .env.example
# ============================================================
