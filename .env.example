# ============================================================
# 🔧 FILE DI CONFIGURAZIONE - .env.example
# ============================================================
# Questo è un file di esempio per le variabili d'ambiente.
#
# ISTRUZIONI:
# 1. Copia questo file come ".env" nella directory root
# 2. Modifica i valori con le tue configurazioni
# 3. NON committare mai il file .env su Git!
#
# Per creare il file .env:
#   cp .env.example .env
#
# ⚠️ SICUREZZA IMPORTANTE:
# - Il file .env contiene dati sensibili (password, chiavi, token)
# - È già incluso in .gitignore per prevenire commit accidentali
# - Genera password sicure per produzione
# - Ruota regolarmente le chiavi di sicurezza
# ============================================================

# === Applicazione ===
APP_NAME="Gestionale Collaboratori e Progetti"
APP_ENV=development  # development | production | staging
APP_VERSION=3.0.0
DEBUG=True  # False in produzione!

# === Server ===
HOST=0.0.0.0
PORT=8000
BACKEND_PORT=8000
FRONTEND_PORT=3001
WORKERS=2  # Numero worker Gunicorn (CPU cores * 2 + 1)
TIMEOUT=60
GRACEFUL_TIMEOUT=20

# === Database PostgreSQL ===
# ⚠️ CAMBIA QUESTE CREDENZIALI IN PRODUZIONE!
DB_NAME=gestionale
DB_USER=admin
DB_PASSWORD=changeme_in_production
DB_HOST=localhost  # In Docker: "db"
DB_PORT=5432  # Porta esterna: 5433 (in docker-compose)

# Connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_ECHO=False  # True per debug SQL

# URL completo (alternativa ai parametri separati)
DATABASE_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# === Redis Cache ===
# ⚠️ IMPOSTA PASSWORD IN PRODUZIONE!
REDIS_HOST=localhost  # In Docker: "redis"
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_pwd
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
# URL Redis completo (costruito automaticamente dai parametri sopra se non impostato)
# In Docker: usare redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_URL=

# === Sicurezza e Autenticazione ===
# ⚠️ CRITICO: OBBLIGATORIO in produzione! Il backend si rifiuta di avviarsi
# se SECRET_KEY è vuota o usa un valore di default noto.
#
# Genera una chiave sicura con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   oppure
#   openssl rand -hex 32
#
# ❌ NON USARE mai questi valori: "changeme_secret_key_super_sicura",
#    "your-super-secret-key-change-in-production", o simili.
SECRET_KEY=  # ← OBBLIGATORIO: genera con il comando sopra
JWT_SECRET_KEY=  # ← come SECRET_KEY (usato da docker-compose)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60  # 1 ora
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
PWD_HASH_ALGORITHM=bcrypt
PWD_SALT_ROUNDS=12

# Bootstrap utenti iniziali
# Lascia vuoto per non creare utenti di default all'avvio.
ADMIN_DEFAULT_PASSWORD=
OPERATOR_DEFAULT_PASSWORD=

# === CORS (Cross-Origin Resource Sharing) ===
# Domini autorizzati (separati da virgola, senza spazi)
# ⚠️ In produzione: specificare solo domini autorizzati (mai wildcard "*"!)
# Esempio produzione: CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3001

# === Logging ===
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=logs/gestionale.log
LOG_FORMAT=json  # json | text
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# === Email (opzionale per notifiche) ===
ENABLE_EMAIL=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=no-reply@gestionale.local
EMAIL_FROM_NAME="Gestionale Collaboratori"

# === WhatsApp (opzionale per agenti outbound) ===
ENABLE_WHATSAPP=False
WHATSAPP_PROVIDER=meta
WHATSAPP_PROVIDER_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_SENDER_ID=
WHATSAPP_TIMEOUT_SECONDS=15
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_GRAPH_VERSION=v17.0
WHATSAPP_META_BASE_URL=https://graph.facebook.com
WHATSAPP_META_WEBHOOK_VERIFY_TOKEN=

# === Upload File ===
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# === Backup Automatico ===
AUTO_BACKUP_ENABLED=false
BACKUP_DIR=backups
BACKUP_RETENTION_COUNT=30
BACKUP_DAILY_TIME=02:00
BACKUP_WEEKLY_TIME=03:00
BACKUP_MONTHLY_INTERVAL_DAYS=30

# === Feature Flags (Abilita/Disabilita Funzionalità) ===
ENABLE_SWAGGER_DOCS=True  # False in produzione per sicurezza
ENABLE_MONITORING=True
ENABLE_AUDIT_LOG=True
ENABLE_PERFORMANCE_TRACKING=True

# Rate Limiting (protezione da abuso API)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# === Monitoring e Metriche ===
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# Sentry (Error Tracking - opzionale)
SENTRY_ENABLED=False
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# === Timezone e Localizzazione ===
TZ=Europe/Rome
LANGUAGE=it
LOCALE=it_IT.UTF-8

# === Environment ===
ENVIRONMENT=development  # development | production | staging

# === Secrets - Servizi Esterni ===
# Se usi servizi esterni, aggiungi qui le chiavi
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=

# === AI Agents / LLM Providers ===
# Provider supportati: none | ollama | openclaw
AI_AGENT_LLM_PROVIDER=none
AI_AGENT_LLM_MODEL=
AI_AGENT_LLM_TIMEOUT_SECONDS=25

# Ollama locale/remoto
OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenClaw / endpoint compatibile OpenAI
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_CHAT_PATH=/v1/chat/completions

# === Email IMAP Worker (Gmail per documenti in arrivo) ===
# Lasciare vuoto per disabilitare il worker di ricezione email
GMAIL_IMAP_USER=
GMAIL_IMAP_APP_PASSWORD=
INBOX_POLL_INTERVAL_SECONDS=300  # Ogni 5 minuti (arq_worker cron)

# ============================================================
# CHECKLIST SICUREZZA PRODUZIONE:
# ============================================================
# OBBLIGATORI:
# [ ] Generare SECRET_KEY/JWT_SECRET_KEY sicura (48+ caratteri random)
# [ ] Impostare password sicure per DB_PASSWORD e REDIS_PASSWORD
# [ ] Impostare DEBUG=False
# [ ] Configurare CORS_ALLOWED_ORIGINS con domini specifici (no wildcard)
# [ ] Impostare REDIS_URL con password in Docker
#
# RACCOMANDATI:
# [ ] Abilitare HTTPS/TLS (reverse proxy nginx/traefik)
# [ ] Configurare backup automatici (AUTO_BACKUP_ENABLED=true)
# [ ] Impostare log retention policy
# [ ] Abilitare monitoring (ENABLE_MONITORING=True)
# [ ] Configurare firewall per database e Redis (no porte pubbliche)
# [ ] Verificare permessi file e directory (uploads, backups)
# [ ] Impostare WORKERS appropriato (CPU*2+1, min 2)
# [ ] Disabilitare Swagger in produzione (ENABLE_SWAGGER_DOCS=False)
# ============================================================

# ============================================================
# FINE .env.example
# ============================================================
