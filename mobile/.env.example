# Mobile App Environment Configuration
# Copy to .env.local and configure for your network

# API Configuration
# IMPORTANT: Replace with your PC's LAN IP (run ipconfig on Windows to find IPv4)
# Examples:
# - Development: http://192.168.1.12:8000
# - Production: https://api.yourapp.com
EXPO_PUBLIC_API_BASE_URL=http://YOUR_PC_IP:8000

# Mock Mode (useful for offline development/demo)
# Set to true to use mock data instead of real API
EXPO_PUBLIC_USE_MOCK=false

# Feature Flags
EXPO_PUBLIC_ENABLE_DEBUG=false
