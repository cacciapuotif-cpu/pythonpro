# ============================================================
# 🔧 CONFIGURAZIONE AMBIENTE - Gestionale Pythonpro
# ============================================================
# File template per variabili d'ambiente Docker Compose
#
# ISTRUZIONI:
# 1. Copia questo file in `.env` nella stessa directory
# 2. Modifica i valori con password sicure per produzione
# 3. Mai committare `.env` su Git!
# ============================================================

# === Database PostgreSQL ===
DB_NAME=gestionale
DB_USER=admin
DB_PASSWORD=changeme_in_production
DB_PORT=5434
# Nota: porta esterna del container (host:container = 5434:5432)

# === Redis Cache ===
REDIS_PASSWORD=changeme_redis_pwd
REDIS_PORT=6379

# === Backend API ===
BACKEND_PORT=8001
WORKERS=2
TIMEOUT=60
GRACEFUL_TIMEOUT=20
LOG_LEVEL=INFO

# === Environment ===
ENVIRONMENT=production
DEBUG=False

# === Security (JWT) ===
# IMPORTANTE: Genera una chiave sicura con: openssl rand -hex 32
JWT_SECRET_KEY=changeme_secret_key_super_sicura_generata_con_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS Origins ===
# Lista separata da virgole o singolo valore
# Esempi:
#   BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
#   BACKEND_CORS_ORIGINS=https://miodominio.com
BACKEND_CORS_ORIGINS=http://localhost:3001

# === Frontend ===
FRONTEND_PORT=3001
# URL backend per browser (usa /api se proxy Nginx, altrimenti http://localhost:8001)
REACT_APP_API_URL=/api

# === AI Agents / LLM Providers ===
AI_AGENT_LLM_PROVIDER=none
AI_AGENT_LLM_MODEL=
AI_AGENT_LLM_TIMEOUT_SECONDS=25
OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_CHAT_PATH=/v1/chat/completions

# ============================================================
# COMANDI UTILI:
# ------------------------------------------------------------
# Genera JWT secret key sicura:
#   openssl rand -hex 32
#
# Avvia stack:
#   docker compose up -d
#
# Rebuild dopo modifiche:
#   docker compose up -d --build
#
# Stop stack:
#   docker compose down
#
# Reset completo (ATTENZIONE: elimina dati!):
#   docker compose down -v
# ============================================================
