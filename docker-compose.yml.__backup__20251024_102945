# ============================================================
# 🐳 DOCKER COMPOSE - PythonPro Stack
# ============================================================
# Stack completo con:
# - PostgreSQL (database)
# - Redis (cache e sessioni)
# - Backend FastAPI
# - Frontend React
# ============================================================

services:
  # === DATABASE POSTGRESQL ===
  db:
    image: postgres:15-alpine
    environment:
      POSTGRES_DB: ${DB_NAME:-gestionale}
      POSTGRES_USER: ${DB_USER:-admin}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-changeme_in_production}
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --locale=it_IT.utf8"
    ports:
      - "${POSTGRES_PORT:-5434}:5432"
    volumes:
      - db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-admin} -d ${DB_NAME:-gestionale}"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 10s
    restart: unless-stopped
    networks:
      - pythonpro_net
    labels:
      - "com.project=pythonpro"
      - "com.role=db"
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1G
        reservations:
          cpus: '0.5'
          memory: 512M

  # === CACHE REDIS ===
  redis:
    image: redis:7-alpine
    command: >
      redis-server
      --appendonly yes
      --maxmemory 256mb
      --maxmemory-policy allkeys-lru
      --requirepass ${REDIS_PASSWORD:-changeme_redis_pwd}
    ports:
      - "${REDIS_PORT:-6381}:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "--raw", "incr", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3
    restart: unless-stopped
    networks:
      - pythonpro_net
    labels:
      - "com.project=pythonpro"
      - "com.role=cache"
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M

  # === BACKEND API (FastAPI) ===
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    working_dir: /app
    environment:
      # Database
      DATABASE_URL: postgresql+psycopg://${DB_USER:-admin}:${DB_PASSWORD:-changeme_in_production}@db:5432/${DB_NAME:-gestionale}
      DB_HOST: db
      DB_PORT: 5432
      DB_USER: ${DB_USER:-admin}
      DB_PASSWORD: ${DB_PASSWORD:-changeme_in_production}
      DB_NAME: ${DB_NAME:-gestionale}

      # Redis
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD:-changeme_redis_pwd}

      # Server
      PORT: 8000
      WORKERS: ${WORKERS:-2}
      TIMEOUT: ${TIMEOUT:-60}
      GRACEFUL_TIMEOUT: ${GRACEFUL_TIMEOUT:-20}

      # Security
      SECRET_KEY: ${JWT_SECRET_KEY:-changeme_secret_key_super_sicura}
      JWT_SECRET_KEY: ${JWT_SECRET_KEY:-changeme_secret_key_super_sicura}
      JWT_ALGORITHM: HS256
      ACCESS_TOKEN_EXPIRE_MINUTES: 60

      # Environment
      ENVIRONMENT: ${ENVIRONMENT:-production}
      DEBUG: ${DEBUG:-False}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}

      # CORS
      BACKEND_CORS_ORIGINS: ${BACKEND_CORS_ORIGINS:-http://localhost:3002}

      # Alembic
      ALEMBIC_CONFIG: /app/alembic.ini
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8000/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 24
      start_period: 120s
    ports:
      - "${BACKEND_PORT:-8002}:8000"
    volumes:
      - backend_uploads:/app/uploads
      - backend_logs:/app/logs
      - backend_backups:/app/backups
      - ./backend:/app
    restart: unless-stopped
    networks:
      - pythonpro_net
    labels:
      - "com.project=pythonpro"
      - "com.role=backend"
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
        reservations:
          cpus: '1.0'
          memory: 1G

  # === FRONTEND (React) ===
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      args:
        REACT_APP_API_URL: http://localhost:${BACKEND_PORT:-8002}
    environment:
      REACT_APP_API_URL: ${REACT_APP_API_URL:-http://localhost:8002}
    depends_on:
      backend:
        condition: service_healthy
    ports:
      - "${FRONTEND_PORT:-3002}:80"
    restart: unless-stopped
    networks:
      - pythonpro_net
    labels:
      - "com.project=pythonpro"
      - "com.role=frontend"
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M

# === VOLUMES (Persist Data) ===
volumes:
  db_data:
    name: ${COMPOSE_PROJECT_NAME:-pythonpro}_db_data
    driver: local
  redis_data:
    name: ${COMPOSE_PROJECT_NAME:-pythonpro}_redis_data
    driver: local
  backend_uploads:
    name: ${COMPOSE_PROJECT_NAME:-pythonpro}_backend_uploads
    driver: local
  backend_logs:
    name: ${COMPOSE_PROJECT_NAME:-pythonpro}_backend_logs
    driver: local
  backend_backups:
    name: ${COMPOSE_PROJECT_NAME:-pythonpro}_backend_backups
    driver: local

# === NETWORK ===
networks:
  pythonpro_net:
    name: ${COMPOSE_PROJECT_NAME:-pythonpro}_net
    driver: bridge

# ============================================================
# COMANDI UTILI:
# ------------------------------------------------------------
# Preflight check:   make preflight
# Avvio stack:       make up
# Stop stack:        make down
# View logs:         make logs
# Smoke test:        make smoke
# ============================================================
