3. NEW FILE: frontend/nginx/frontend.conf
================================================================================
+++ frontend/nginx/frontend.conf (new file)
@@ -0,0 +1,62 @@
+server {
+  listen 80;
+  server_name _;
+
+  # Security headers
+  add_header X-Frame-Options "SAMEORIGIN" always;
+  add_header X-Content-Type-Options "nosniff" always;
+  add_header Referrer-Policy "no-referrer-when-downgrade" always;
+  add_header X-XSS-Protection "1; mode=block" always;
+  add_header Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https: http:; font-src 'self' data:;" always;
+
+  # Gzip compression for text-based assets
+  gzip on;
+  gzip_vary on;
+  gzip_proxied any;
+  gzip_comp_level 6;
+  gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/rss+xml font/truetype font/opentype application/vnd.ms-fontobject image/svg+xml;
+  gzip_min_length 1024;
+
+  # Serve frontend static files
+  root /usr/share/nginx/html;
+  index index.html;
+
+  # Cache static assets aggressively (cache busting via hashes in filenames)
+  location ~* \.(?:js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$ {
+    expires 1y;
+    access_log off;
+    add_header Cache-Control "public, immutable";
+    try_files $uri =404;
+  }
+
+  # API reverse proxy to backend container
+  location /api/v1/ {
+    proxy_pass         http://backend:8000/api/v1/;
+    proxy_http_version 1.1;
+    proxy_set_header   Upgrade $http_upgrade;
+    proxy_set_header   Connection "upgrade";
+    proxy_set_header   Host $host;
+    proxy_set_header   X-Real-IP $remote_addr;
+    proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
+    proxy_set_header   X-Forwarded-Proto $scheme;
+
+    # Timeouts
+    proxy_connect_timeout 60s;
+    proxy_send_timeout 60s;
+    proxy_read_timeout 60s;
+
+    # Buffering
+    proxy_buffering off;
+  }
+
+  # Health endpoint for load balancer / uptime monitoring
+  location = /healthz {
+    access_log off;
+    return 200 'ok';
+    add_header Content-Type text/plain;
+  }
+
+  # Single Page Application fallback
+  location / {
+    try_files $uri $uri/ /index.html;
+  }
+}

FEATURES:
- Serves React SPA with fallback routing
- Reverse proxy /api/v1 → backend:8000
- Security headers (XSS, frame options, CSP)
- Gzip compression for performance
- Aggressive caching for static assets
- Health endpoint at /healthz

