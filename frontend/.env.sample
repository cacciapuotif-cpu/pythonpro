# === API Configuration ===
# Per sviluppo con backend locale diretto (senza Docker):
REACT_APP_API_URL=http://localhost:8001

# Per produzione Docker (con proxy Nginx):
# REACT_APP_API_URL=/api

# === Development Server ===
PORT=3001
WDS_SOCKET_PORT=3001

# === Build Configuration ===
GENERATE_SOURCEMAP=false
SKIP_PREFLIGHT_CHECK=true
